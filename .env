# ── Server ───────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=https://clubeasa.com

# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://clubeasa:clubeasa@cluster0.wvpoqj2.mongodb.net/clubeasa?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=clubeasa_super_secret_key_2024

# ── Email (for password reset) ───────────────────────────────
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── LemonSqueezy ─────────────────────────────────────────────
# 1. API Key      → https://app.lemonsqueezy.com/settings/api
# 2. Store ID     → https://app.lemonsqueezy.com/settings/stores
# 3. Webhook Secret → https://app.lemonsqueezy.com/settings/webhooks
# 4. Variant IDs  → Products → your product → Variants → copy ID from URL

LEMONSQUEEZY_API_KEY=your_api_key_here
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret_here
LEMONSQUEEZY_STORE_ID=your_store_id_here

LS_VARIANT_MONTHLY=111111
LS_VARIANT_BIMONTHLY=222222
LS_VARIANT_QUARTERLY=333333
