# Server
PORT=5000

# MongoDB (Free from MongoDB Atlas)
MONGODB_URI=mongodb+srv://yourusername:yourpassword@cluster0.mongodb.net/clubeasa

# JWT
JWT_SECRET=clubeasa_super_secret_key_change_this_in_production
JWT_EXPIRE=30d

# Khalti Configuration
KHALTI_SECRET_KEY=test_secret_key_your_khalti_test_key
KHALTI_PUBLIC_KEY=test_public_key_your_khalti_test_key
KHALTI_BASE_URL=https://khalti.com/api/v2

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin Email (for notifications)
ADMIN_EMAIL=admin@clubeasa.com